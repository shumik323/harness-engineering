# .harness.conf — конфигурация харнесса для этого проекта
# Скопируй в корень репо как `.harness.conf`, заполни под свой проект.
# Этот файл читается скриптами в .claude/guards/ и .claude/commands/

# --- Sensor ---

# Директория за которой следит хук при изменениях файлов.
# Используется в run-test-hook.sh для фильтрации (нет изменений → молчим).
# Пример: "packages/ui-kit/lib" или "src"
WATCH_DIR="src"

# Команда запуска тестов. Должна принимать список файлов как аргументы.
# Пример: "vitest related --run" или "jest --testPathPattern"
TEST_CMD="vitest related --run"

# --- Guard ---

# Зоны которые запрещено редактировать напрямую (генерированные файлы).
# Пробел-разделённый список директорий.
# Хук block-zones.sh вернёт exit 2 при попытке записи в эти пути.
READONLY_ZONES="dist"

# --- Gate (Ярус 2/3) ---

# Ярус 2 (Stop hook + база pre-push): repo-wide проверка БЕЗ полных тестов.
# Sensor пофайловый — он не ловит type-ошибки по проекту, линт, сборку и
# поломки конфигов. Gate ловит. Пусто → fail-open (gate выключен).
# Тестов тут нет намеренно: полный прогон медленный для каждого хода агента,
# на Stop их закрывает sensor (TEST_CMD пофайлово). Примеры:
#   turbo:  "turbo type-check lint build"
#   npm:    "npm run type-check && npm run lint && npm run build"
GATE_CMD="turbo type-check lint build"

# Ярус 3 (только pre-push): полный прогон тестов поверх GATE_CMD.
# Push — редкое событие, медленно допустимо; turbo-кэш делает cache-hit
# почти мгновенным. Дыра, которую закрывает: массовый lint:fix/format через
# Bash обходит sensor (он ловит только Edit/Write) → снапшоты/тесты ломаются
# молча и всплывают только в CI. Пусто → тесты на push не гоняются. Примеры:
#   turbo:  "turbo test"
#   npm:    "npm run test"
GATE_TEST_CMD="turbo test"

# Откуда запускать GATE_CMD (по умолчанию REPO_ROOT). Обычно пусто.
GATE_WORKDIR=""

# --- Memory ---

# Путь к долгосрочной памяти проекта в TechWiki (или другой вики).
# Используется в load-context.sh (SessionStart) и end-session.md.
# Пример: "/Users/shumik/Desktop/TechWiki/wiki/projects/ui-kit-harness"
WIKI_PATH=""

# --- Repo ---

# Корень репозитория (обычно $PWD при запуске хука).
# Переопределяй только если структура нестандартная.
REPO_ROOT="${REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
