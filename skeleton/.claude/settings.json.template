{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${REPO_ROOT}/.claude/guards/block-zones.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${REPO_ROOT}/.claude/guards/block-zones.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${REPO_ROOT}/.claude/guards/run-test-hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${REPO_ROOT}/scripts/load-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Сессия завершается. Если в этой сессии была реальная работа — запусти /end-session чтобы обновить лог. Если нет — просто подтверди завершение."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx vitest related --run *)",
      "Bash(bash .claude/guards/*.sh)"
    ]
  }
}
