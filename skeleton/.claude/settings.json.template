{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guards/block-zones.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guards/block-zones.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guards/nudge.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guards/run-test-hook.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guards/gate.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/load-context.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Сессия завершается. Если была реальная работа — выполни логику end-session НАПРЯМУЮ (слэш-команду вызвать нельзя, если она disable-model-invocation): triage буфера наблюдений (one-off → log, повторяемое правило → новый раздел в gotchas/реестре правил, ADR → decisions), затем допиши запись в <WIKI_PATH>/log (Что сделал / Что удивило / Что завтра) и очисти буфер. Если работы не было — ничего не делай."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(<TEST_CMD> *)",
      "Bash(bash .claude/guards/*.sh)"
    ]
  }
}
