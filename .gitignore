# macOS
.DS_Store

# Сторонние методологии — не часть шаблона (см. rules/common/methodology-routing.md)
.superpowers/

# Copier: артефакт рендера, если случайно запущен в корне шаблона
# (skeleton/.copier-answers.yml.jinja — НЕ игнорировать, это источник)
/.copier-answers.yml

# Node (защитно — в шаблоне нет, но инстансы тянут)
node_modules/
*.log

# Локальное окружение
.env
.env.local

# Временные/скретч
*.orig
*.tmp

# Внутренняя операционка / приватное — не в публичный шаблон.
# Низкая чувствительность → без scrub истории (остаются в прошлых коммитах).
# Файлы остаются ЛОКАЛЬНО (полезны), уходят из трекинга через git rm --cached.
/REGISTRY.md
/docs/plans/
/docs/specs/
/skeleton/.claude/rules/lang/md-libs.md
